# Configuration SMTP pour LWS
SMTP_HOST=xxxxxx
SMTP_USER=xxxxx
SMTP_PASS=votre_mot_de_passe_smtp

# Email de destination pour les messages de contact
CONTACT_EMAIL=xxxxx@ascencia.re

# Configuration reCAPTCHA v3
RECAPTCHA_SITE_KEY=votre_clé_site_recaptcha
RECAPTCHA_SECRET_KEY=votre_clé_secrète_recaptcha

# --- Covert Commissions (rotation temps réel) ---
# Base Neon Postgres — le site LIT les rotations ici (lecture seule).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Auth Discord (Auth.js) ---
# Générer AUTH_SECRET avec : bunx auth secret
AUTH_SECRET=votre_secret_authjs
AUTH_DISCORD_ID=votre_client_id_discord
AUTH_DISCORD_SECRET=votre_client_secret_discord
# IDs Discord promus admin automatiquement, séparés par virgules.
ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
# En production, définir l'URL publique du site si l'auto-détection Vercel ne suffit pas.
AUTH_URL=https://dna.ascencia.re

# Instructions:
# 1. Créez un fichier .env.local dans la racine du projet
# 2. Copiez ces variables dans ce fichier
# 3. Remplacez les valeurs par vos vraies informations
# 4. Pour obtenir les clés reCAPTCHA, allez sur https://www.google.com/recaptcha/admin
