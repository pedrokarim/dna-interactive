# --- SMTP (LWS) ---
# Sert À LA FOIS au formulaire de contact ET aux emails d'auth (vérification,
# reset, définition de mot de passe, bienvenue) via src/lib/email/mailer.ts.
# Transport : port 465 SSL, expéditeur = SMTP_USER.
#
# ⚠️ SMTP_HOST = ton serveur LWS assigné, au format `mailNN.lwspanel.com`.
#    Le "l" de "mail" est une lettre L, PAS le chiffre 1 (coquille classique
#    `mai1..` / `mail1..`). Vérifie qu'il RÉSOUT en DNS avant de déployer :
#      nslookup mail52.lwspanel.com   (doit renvoyer une IP)
SMTP_HOST=mail52.lwspanel.com
SMTP_USER=contact@ascencia.re
SMTP_PASS=votre_mot_de_passe_smtp

# Email de destination pour les messages de contact
CONTACT_EMAIL=contact@ascencia.re

# Configuration reCAPTCHA v3
RECAPTCHA_SITE_KEY=votre_clé_site_recaptcha
RECAPTCHA_SECRET_KEY=votre_clé_secrète_recaptcha

# --- Base de données (Postgres partagé "Kagura", cf. docs/base-de-donnees-kagura.md) ---
# TLS OBLIGATOIRE en verify-full : `require` chiffre mais NE vérifie PAS le
# certificat (MITM possible). Ne jamais dégrader en `require`/`prefer` en prod.
DATABASE_URL=postgresql://dna:password@db.ascencia.re:5432/dna?sslmode=verify-full

# --- Auth (Auth.js v5, sessions JWT) ---
# Générer AUTH_SECRET avec : bun x auth secret. Sert aussi de sel au hash des
# votes anonymes par IP (lib/community-builds/vote-identity.ts).
AUTH_SECRET=votre_secret_authjs
AUTH_DISCORD_ID=votre_client_id_discord
AUTH_DISCORD_SECRET=votre_client_secret_discord
# Google OAuth : optionnel. Le provider ne s'active que si les DEUX sont définis.
AUTH_GOOGLE_ID=votre_client_id_google
AUTH_GOOGLE_SECRET=votre_client_secret_google
# IDs Discord promus admin automatiquement, séparés par virgules.
ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
# En production, définir l'URL publique du site si l'auto-détection Vercel ne suffit pas.
AUTH_URL=https://dna.ascencia.re

# Instructions:
# 1. Créez un fichier .env.local dans la racine du projet
# 2. Copiez ces variables dans ce fichier
# 3. Remplacez les valeurs par vos vraies informations
# 4. Pour obtenir les clés reCAPTCHA, allez sur https://www.google.com/recaptcha/admin
