      (() => {
        const CF_MATCH = [
          "challenges.cloudflare.com",
          "cdn-cgi/challenge-platform",
        ];

        const suppress = (original, args) => {
          const msg = args?.[0];
          if (
            typeof msg === "string" &&
            CF_MATCH.some((d) => msg.includes(d))
          ) {
            return; // ignore Cloudflare noise
          }
          original.apply(console, args);
        };

        ["error", "warn", "info", "debug"].forEach((method) => {
          const original = console[method];
          console[method] = (...args) => suppress(original, args);
        });

        // suppress network/resource load errors
        window.addEventListener(
          "error",
          (event) => {
            if (
              event?.target?.src &&
              CF_MATCH.some((d) => event.target.src.includes(d))
            ) {
              event.stopImmediatePropagation();
            }
          },
          true,
        );
      })();
    </script><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><link rel="icon" type="image/svg+xml" href="https://files.boarhat.gg/assets/main/boarhat_icon_v2.png"><meta name="generator" content="Astro v5.15.9"><link rel="sitemap" href="/sitemap-index.xml"><link rel="stylesheet" href="/styles/global.css"><title>
